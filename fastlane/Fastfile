files_with_version_number = {
  './purchases/src/main/kotlin/com/revenuecat/purchases/common/Config.kt' => ['frameworkVersion = "{x}"'],
  './.circleci/config.yml' => ['aws s3 sync ~/project/docs/{x} s3://purchases-docs/android/{x} --delete'],
  './gradle.properties' => ['VERSION_NAME={x}'],
  './.version' => ['{x}'],
  './examples/MagicWeather/gradle/libs.versions.toml' => ['purchases = "{x}"'],
  './examples/MagicWeatherCompose/gradle/libs.versions.toml' => ['purchases = "{x}"'],
  './examples/CustomEntitlementComputationSample/gradle/libs.versions.toml' => ['purchases = "{x}"'],
  './test-apps/sdksizetesting/gradle/libs.versions.toml' => ['purchases = "{x}"'],
}
files_to_update_on_latest_stable_releases = {
  './docs/index.html' => ['url=https://sdk.revenuecat.com/android/{x}/index.html'],
}

repo_name = 'purchases-android'
changelog_latest_path = './CHANGELOG.latest.md'
changelog_path = './CHANGELOG.md'

default_platform(:android)

# Hack to work around a Fastlane quirk where plugin actions are run from the parent of the current working directory.
# We switch to the first subdirectory, then run the action. The action will run from the parent of the subdirectory, which is
# our actual current working directory. The obvious limitation is that this doesn't work if the current working directory
# does not have any subdirectories.
# This is only needed when our current working directory is not the ./fastlane directory.
# https://docs.fastlane.tools/advanced/fastlane/#directory-behavior
def run_plugin_action_in_current_directory(&block)
  Dir.chdir(Dir["*/"].first.chomp("/"), &block)
end

platform :android do
  desc "Fetch integration test secrets from 1Password and write them to local.properties"
  desc "Requires the 1Password CLI (op) to be installed and signed in"
  lane :setup_local_properties do
    op_vault = "Mobile"
    op_item = "Purchases Android SDK local.properties"
    local_props_path = File.join(Dir.pwd, '..', 'local.properties')

    # All fields to fetch from 1Password and write to local.properties
    fields = %w[
      PAYWALL_TESTER_API_KEY_A
      PURCHASE_TESTER_API_KEY
      BACKEND_INTEGRATION_API_KEY
      BACKEND_INTEGRATION_LOAD_SHEDDER_API_KEY
      REVENUECAT_API_KEY
      GOOGLE_PURCHASE_TOKEN
      PRODUCT_ID_TO_PURCHASE
      BASE_PLAN_ID_TO_PURCHASE
      ACTIVE_ENTITLEMENT_IDS_TO_VERIFY
      LOAD_SHEDDER_REVENUECAT_API_KEY
      LOAD_SHEDDER_GOOGLE_PURCHASE_TOKEN
      LOAD_SHEDDER_PRODUCT_ID_TO_PURCHASE
      LOAD_SHEDDER_BASE_PLAN_ID_TO_PURCHASE
      LOAD_SHEDDER_ACTIVE_ENTITLEMENT_IDS_TO_VERIFY
      CUSTOM_ENTITLEMENT_COMPUTATION_REVENUECAT_API_KEY
      CUSTOM_ENTITLEMENT_COMPUTATION_GOOGLE_PURCHASE_TOKEN
      CUSTOM_ENTITLEMENT_COMPUTATION_PRODUCT_ID_TO_PURCHASE
      CUSTOM_ENTITLEMENT_COMPUTATION_BASE_PLAN_ID_TO_PURCHASE
      CUSTOM_ENTITLEMENT_COMPUTATION_ACTIVE_ENTITLEMENT_IDS_TO_VERIFY
    ]

    # Check that the 1Password CLI is installed
    unless system('which op > /dev/null 2>&1')
      UI.user_error!(
        "1Password CLI (op) is not installed.\n" \
        "Install it with: brew install 1password-cli\n" \
        "More info: https://developer.1password.com/docs/cli/get-started/"
      )
    end

    # Check that the user is signed in
    unless system('op account list > /dev/null 2>&1')
      UI.user_error!(
        "Not signed in to 1Password CLI.\n" \
        "Sign in with: op signin"
      )
    end

    UI.message("Fetching secrets from 1Password item '#{op_item}' in vault '#{op_vault}'...")

    # Read existing local.properties to preserve non-secret entries (e.g. sdk.dir)
    existing_lines = []
    existing_keys = {}
    if File.exist?(local_props_path)
      existing_lines = File.readlines(local_props_path)
      existing_lines.each do |line|
        stripped = line.strip
        next if stripped.empty? || stripped.start_with?('#')
        key, = stripped.split('=', 2)
        existing_keys[key] = true
      end
    end

    # Fetch all fields from 1Password in a single call
    field_labels = fields.map { |f| "label=#{f}" }.join(',')
    json_output = `op item get "#{op_item}" --vault "#{op_vault}" --fields "#{field_labels}" --format json 2>&1`
    unless $?.success?
      UI.user_error!("Failed to fetch secrets from 1Password. Make sure the 'op' CLI is installed and you are signed in.\n#{json_output}")
    end

    fetched_fields = JSON.parse(json_output)
    secrets = {}
    fetched_fields.each do |field|
      secrets[field['label']] = field['value'] || ''
    end

    # Build new local.properties content
    # If an existing value differs from 1Password, comment out the old line and add the new one
    updated_count = 0
    commented_count = 0
    new_lines = existing_lines.flat_map do |line|
      stripped = line.strip
      if stripped.empty? || stripped.start_with?('#')
        [line]
      else
        key, old_value = stripped.split('=', 2)
        if secrets.key?(key)
          new_value = secrets.delete(key)
          updated_count += 1
          if old_value == new_value
            [line]
          else
            commented_count += 1
            [
              "# Previous value (replaced by setup_local_properties):\n",
              "# #{stripped}\n",
              "#{key}=#{new_value}\n",
            ]
          end
        else
          [line]
        end
      end
    end

    # Append any new secrets that weren't already in the file
    unless secrets.empty?
      new_lines << "\n" unless new_lines.last&.strip&.empty?
      new_lines << "# Added by setup_local_properties from 1Password\n"
      secrets.each do |key, value|
        new_lines << "#{key}=#{value}\n"
      end
    end

    File.write(local_props_path, new_lines.join)
    added_count = fields.length - updated_count
    UI.success("local.properties updated: #{updated_count} updated (#{commented_count} had different values), #{added_count} added")
  end

